-- join finalbasetable pm on pm.mem_id = ag.mem_id
-- where ag.latest_flag = 'A'
-- and ag.activity = 'S'
-- and ag.is_tg = 'N'

base AS (
    SELECT 
        pm.*,
        ag.final_pre_tax_revenue,
        ag.activity_date,
        CAST(date_trunc('month', ag.activity_date) AS DATE) AS activity_month_start_date,
        ag.lob_reporting AS sales_lob_reporting,
        ag.category,
        ag.partner_name,
        ag.plan_name,
        ag.plan_service_code_list
    FROM reports_sales.oa_master_sales_agg_dtl ag 
    JOIN finalbasetable pm 
        ON pm.mem_id = ag.mem_id
    WHERE ag.latest_flag = 'A'
      AND ag.activity = 'S'
      AND ag.is_tg = 'N'
      and cast(ag.activity_date as date) >= date '2025-01-01'
),

cost_calc AS (
    SELECT
        *,
        SUM(COALESCE(ic_premium_system, 0)) 
            OVER (PARTITION BY mem_id) AS total_mem_cost
    FROM base
),

final as(SELECT
    *,
    
    CASE 
        WHEN service_type = 'only_pms' THEN 1.0
        WHEN total_mem_cost = 0 THEN 0
        ELSE ROUND(
            COALESCE(ic_premium_system, 0) / total_mem_cost,
            6
        )
    END AS cost_pct,

    CASE 
        WHEN service_type = 'only_pms' THEN final_pre_tax_revenue
        WHEN total_mem_cost = 0 THEN 0
        ELSE ROUND(
            final_pre_tax_revenue * COALESCE(ic_premium_system, 0) / total_mem_cost,
            2
        )
    END AS split_revenue

FROM cost_calc 
ORDER BY mem_id, service_type, service_code)

select mem_id,service_code,lob_reporting,
case when plan_service_code_list = 'HA_BD' then 'core' else service_type end as "service_type",
plan_id, final_pre_tax_revenue, activity_date,
activity_month_start_date,category,partner_name,plan_name,
plan_service_code_list,split_revenue,ic_premium_system,
CASE
    WHEN service_code IN ('HA_FR') THEN 'Fire Protection'

    WHEN service_code IN (
        'PE_ADLD','HA_BD','EMIPROTECTCV','HA_EW','PE_EW','HA_AD',
        'PE_BD','BUYBACK','FURN_BD','MOBILESECURITY',
        'EXTENDED WARRAN','AADHAAR_SERVICE','INCOME_LOSS_CV',
        'EMI_PROTECT_HOSPI','only_pms'
    ) THEN 'Core'

    WHEN service_code IN (
        'PAYMENT_FRAUD_TXN',
