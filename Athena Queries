    WHEN service_code IN (
        'DL_REPLACE',
        'PAN_REPLACE'
    ) THEN 'ID Services'

    WHEN service_code IN ('LOAN_GUARD') THEN 'Loan Protection'

    WHEN service_code IN (
        'SonyLIV+Mobile ONLY - 1 Yr',
        'Amazon Prime Lite+Amazon Prime Lite 12M',
        'Amazon Prime+Amazon Prime - 3M',
        'Sony LIV+3Month Premium',
        'OTT+Jhakaas Monthly',
        'JioHotstar+Hotstar 1 year',
        'OTT+South OTT pack',
        'Amazon Prime+Prime Video 1-year',
        'Sony LIV+Premium 1-year',
        'Zee5+Premium 1- year'
    ) THEN 'OTT Voucher'

    WHEN service_code IN (
        'Gaana Plus+3 months',
        'Gaana Plus+1 year'
    ) THEN 'OTT - Music Voucher'

    WHEN service_code IN (
        'TC',
        'TELECONSULTATION_SP',
        'EPRES',
        'DT',
        'AMBULANCE_SERVICE'
    ) THEN 'Health Services'

    WHEN service_code IN (
        'ACCIDENTAL_HOSPI',
        'P ACCIDENT COV'
    ) THEN 'Accidental Protection'

    WHEN service_code IN (
        'CI',
        'OPD_WALLET',
        'EYE_INJURY_COVER',
        'HC'
    ) THEN 'Health Protection'

    --WHEN service_code IN ('only_pms') THEN 'Appliance Care'

    WHEN service_code IN (
        'CREDIT SHIELD',
        'CC',
        'DARK_WEB_MONITORING',
        'CREDIT_SCORE'
    ) THEN 'Cyber'

    WHEN service_code IN ('Medibuddy+500 Voucher') THEN 'Pharmacy Voucher'

    WHEN service_code IN (
        'PE_THEFT',
        'HA_BR',
        'THEFT'
    ) THEN 'Theft Protection'

    WHEN service_code IN (
        'MOTOR_AMC'
    ) THEN 'Motor AMC'

    WHEN service_code IN (
        'ONEASSIST_REWARDS',
        'Amazon Shopping+Rs.400 Shopping balance'
    ) THEN 'Shopping Voucher'

    WHEN service_code IN (
        'KEY_AST_TYRE_COVER',
        'ROAD_SIDE_AST',
        'KA'
    ) THEN 'RSA'

    WHEN service_code IN (
        'Quick Heal+Total Security 3M',
        'Quick Heal+Antivirus Pro 3M',
        'Quick Heal+AntiFraud AI 6M',
        'Quick Heal+Total Security Android 6M'
    ) THEN 'Device Protection Voucher'

    WHEN service_code IN (
        'Vehicle Care+3 years'
    ) THEN 'Motor Subscription'

    WHEN service_code IN (
        'LS_DAMAGE',
        'P PROTECTION'
    ) THEN 'Lifestyle Protection'

    WHEN service_code IN (
        'COURTESY'
    ) THEN 'Other VAS'

    ELSE 'Unmapped'
END AS sub_category
from final 
where plan_name = '3Y OneAssist AC Care For Air Conditioner With 6PMS_3GC_UL Visits (2025)'


